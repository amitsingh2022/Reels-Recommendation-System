SERVICE_NAME=reels-recommendation-api
ENVIRONMENT=dev
LOG_LEVEL=INFO
MODEL_ADMIN_API_KEY=change-me
ENABLE_RELOAD_ENDPOINT=true
CORS_ALLOW_ORIGINS=*
REQUEST_CACHE_TTL_SECONDS=30
REQUEST_CACHE_MAX_ITEMS=5000
RATE_LIMIT_REQUESTS_PER_MINUTE=120
INTERACTIONS_PATH=data/interactions.csv
TWO_TOWER_PATH=training/two_tower_model.pth
RANKER_PATH=training/ranker_model.pth
REEL_EMBEDDINGS_PATH=data/processed/reel_embeddings.npy
REEL_IDS_PATH=data/processed/reel_ids.npy
